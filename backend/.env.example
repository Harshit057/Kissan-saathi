# KisanSaathi Backend Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# CORE SETTINGS
# ============================================================================
APP_NAME=KisanSaathi API
DEBUG=false
VERSION=0.1.0

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/kisaan_saathi
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================

# OpenAI API (for GPT-4o LLM)
OPENAI_API_KEY=sk-...

# Bhashini API (Government of India - Free Translation & ASR)
BHASHINI_API_KEY=your-bhashini-api-key

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Shiprocket Logistics API
SHIPROCKET_API_TOKEN=...

# AWS S3 (for media storage)
AWS_S3_BUCKET=kisaan-saathi
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1

# ============================================================================
# FIREBASE CONFIGURATION (for Push Notifications)
# ============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=...
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-key.json

# ============================================================================
# TWILIO CONFIGURATION (for SMS)
# ============================================================================
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ============================================================================
# QDRANT VECTOR DATABASE (for RAG)
# ============================================================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN=https://...@sentry.io/...

# ============================================================================
# APPLICATION LOGIC
# ============================================================================
NEARBY_FARMERS_RADIUS_KM=100
REGIONAL_ORGANIC_RADIUS_KM=300
MANDI_PRICE_CACHE_TTL_HOURS=1
SCHEME_DATA_CACHE_TTL_HOURS=24
