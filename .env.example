# KisanSaathi & आपनGaon Frontend Configuration

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Map Configuration (for marketplace location display)
NEXT_PUBLIC_MAP_API_KEY=your_mapbox_or_google_key_here
NEXT_PUBLIC_MAP_PROVIDER=mapbox  # or 'google'

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_SCHEMES=true
NEXT_PUBLIC_ENABLE_MANDI_PRICES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Sentry Error Tracking (Optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# App Settings
NEXT_PUBLIC_APP_NAME=KisaanSathi
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_ENVIRONMENT=development
